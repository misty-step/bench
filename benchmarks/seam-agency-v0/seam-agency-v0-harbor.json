      }
    ]
  },
  "aggregation": "proportion",
  "uncertainty": {
    "method": "wilson",
    "confidence": 0.95
  },
  "decision": "Qualify the seven-task public development corpus before any real candidate or cross-harness Seam Agency experiment.",
  "runner": {
    "kind": "harbor_task",

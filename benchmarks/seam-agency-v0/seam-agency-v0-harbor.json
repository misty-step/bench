        },
        {
          "task_id": "extend-provider-routing",
          "task_dir": "harbor/extend-provider-routing"
        },
        {
          "task_id": "extend-comparison-attribution",
          "task_dir": "harbor/extend-comparison-attribution"
        },
        {
          "task_id": "repair-memory-extraction",
          "task_dir": "harbor/repair-memory-extraction"
        },
        {

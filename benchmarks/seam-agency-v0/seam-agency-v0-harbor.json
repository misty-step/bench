{
  "schema_version": "crucible.eval_spec.v1",
  "id": "seam-agency-v0-harbor-qualification",
  "title": "Seam Agency v0 seven-task development corpus qualification",
  "context": "Seven Bench-owned public development tasks across Build, Extend, Repair, and Critique. Oracle execution qualifies references only and is not agent performance evidence.",
  "task": "seam-agency-v0",
